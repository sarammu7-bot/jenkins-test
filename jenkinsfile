pipeline {

    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/yourusername/footwear-shop.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('backend') {
                    sh 'npm install'
                }
            }
        }

        stage('Start Backend') {
            steps {
                dir('backend') {
                    sh '''
                    pkill node || true
                    nohup node server.js > app.log 2>&1 &
                    '''
                }
            }
        }

        stage('Deploy Frontend') {
            steps {
                sh '''
                sudo mkdir -p /var/www/html
                sudo cp -r frontend/* /var/www/html/
                '''
            }
        }
    }
}
